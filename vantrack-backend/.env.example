# =============================================================
# VARIÁVEIS DE AMBIENTE — Vantrack Backend
# =============================================================
# Para usar: Copie este arquivo para .env e preencha os valores
# NUNCA compartilhe credenciais reais no repositório

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_DATABASE=vantrack_db
DB_PORT=3306

# CORS Configuration (Frontend URL)
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# JWT Secret (para autenticação futura)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=7d

# Email Configuration (para recuperação de senha)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_app_aqui
SMTP_FROM=noreply@vantrack.com

# Mapbox Token (para integração GPS)
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
BCRYPT_ROUNDS=10
SESSION_SECRET=your_session_secret_here
