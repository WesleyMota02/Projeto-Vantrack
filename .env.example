# =============================================================
# VARIÁVEIS DE AMBIENTE — Vantrack Backend
# =============================================================
# Para usar: Copie este arquivo para .env e preencha os valores
# não compartilhe credenciais reais no repositório

# Database Configuration
DATABASE_URL=postgresql://usuario:senha@localhost:5432/vantrack_db

# JWT Configuration
JWT_SECRET=sua-chave-secreta-aqui-min-32-caracteres
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# Application Settings
API_PORT=5000
API_HOST=0.0.0.0
