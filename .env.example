# =============================================================
# VARIÁVEIS DE AMBIENTE — Vantrack Frontend
# =============================================================
# Para usar: Copie este arquivo para .env e preencha os valores
# não compartilhe credenciais reais no repositório

# API Configuration
API_BASE_URL=http://localhost:3000/api

# Mapbox Configuration (para GPS)
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Application Environment
NODE_ENV=development

# Feature Flags
ENABLE_BETA_FEATURES=false
